# ─── Argus OSINT — .env.example ───────────────────────────────────────────
# Copy to .env and fill in. Only TELEGRAM_BOT_TOKEN is required.

# ─── REQUIRED ─────────────────────────────────────────────────────────────
# Get from @BotFather (https://t.me/botfather)
TELEGRAM_BOT_TOKEN=

# ─── CORE ─────────────────────────────────────────────────────────────────
# Session secret — auto-generated if blank, but set a stable value for
# JWT tokens to survive restarts (important on free-tier deployments!)
SESSION_SECRET=

# Database URL — SQLite by default. For production, use Postgres:
#   ARGUS_DB_URL=postgresql+asyncpg://user:pass@host/db
ARGUS_DB_URL=sqlite+aiosqlite:///./argus.db

# Port for FastAPI + web dashboard
API_PORT=8000

# CORS — comma-separated. Use a specific origin in prod (e.g. https://yourapp.com)
CORS_ORIGINS=*

# ─── PERFORMANCE (low-end tuning) ─────────────────────────────────────────
# Max parallel plugin runs per investigation. Lower = less RAM, slower.
# Termux: 2, Render/Railway free: 3-5, Desktop: 5-10
MAX_CONCURRENT_PLUGINS=5

# Per-investigation timeout (seconds). Each plugin gets timeout/count.
INVESTIGATION_TIMEOUT_SECONDS=120

# Auto-purge investigations older than N days (0 = never)
DATA_RETENTION_DAYS=90

# ─── AI REPORTS (all optional) ───────────────────────────────────────────
# Google Gemini (free tier — https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Ollama local LLM — runs fully offline. Install from https://ollama.ai
# Set ENABLE_OLLAMA=true and pull a small model:
#   ollama pull llama3.2:1b  (1.3GB, runs on 4GB RAM)
ENABLE_OLLAMA=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# ─── OPTIONAL FREE API KEYS (no credit card required) ────────────────────
# All optional — plugins gracefully skip when keys are missing.

# VirusTotal free tier — https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# urlscan.io free — https://urlscan.io/user/profile/
URLSCAN_API_KEY=

# AlienVault OTX free — https://otx.alienvault.com/api
OTX_API_KEY=

# Censys free — https://search.censys.io/account/api
CENSYS_API_ID=
CENSYS_API_SECRET=

# Steam Web API — https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# Etherscan free — https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# ─── NOTIFICATIONS (optional) ───────────────────────────────────────────
# SMTP for email alerts
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=
